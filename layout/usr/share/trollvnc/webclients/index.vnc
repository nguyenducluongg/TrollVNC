<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>$USER's $DESKTOP</title>
    <style>
        * {
            box-sizing: border-box;
            user-select: none;
            -webkit-user-select: none;
        }
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #1c1c1e;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Top status bar */
        #status_bar {
            background: rgba(30, 30, 30, 0.75);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            color: #d1d1d6;
            font-size: 13px;
            font-weight: 500;
            padding: 8px 16px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 10;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .status_left, .status_right {
            display: flex;
            align-items: center;
        }
        .port_text {
            font-size: 11px;
            color: #8e8e93;
            font-weight: 600;
        }
        .header_stats {
            display: flex;
            gap: 10px;
            align-items: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .stat_badge {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            color: #e5e5ea;
        }
        .color_green { color: #30d158; }
        .color_orange { color: #ff9f0a; }
        .color_red { color: #ff453a; }

        @media (max-width: 600px) {
            #status_bar {
                padding: 6px 8px;
            }
            .header_stats {
                gap: 5px;
            }
            .stat_badge {
                padding: 2px 4px;
                font-size: 10px;
            }
            .port_text {
                display: none;
            }
        }
        #status_text {
            font-weight: 600;
        }
        .vnc_icon {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }
        .status_connecting { background-color: #ff9f0a; }
        .status_connected { background-color: #30d158; }
        .status_disconnected { background-color: #ff453a; }

        .status_btn {
            background: #30d158;
            border: none;
            color: #ffffff;
            padding: 6px 14px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            outline: none;
            transition: all 0.2s ease;
            margin-right: 12px;
        }
        .status_btn.connected {
            background: #ff453a;
        }
        .status_btn:hover {
            opacity: 0.9;
            transform: scale(1.03);
        }
        .status_btn:active {
            transform: scale(0.97);
        }

        /* Space for top bar */
        #screen {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            padding-top: 36px;
            padding-bottom: 80px;
        }

        /* Premium Floating Control Dock */
        #control_dock {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(30, 30, 30, 0.65);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 20px;
            padding: 10px 18px;
            display: flex;
            gap: 16px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
            z-index: 100;
            pointer-events: auto;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        #control_dock:hover {
            background: rgba(40, 40, 40, 0.75);
            border-color: rgba(255, 255, 255, 0.25);
            box-shadow: 0 16px 50px rgba(0, 0, 0, 0.6);
        }
        
        .dock_btn {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            outline: none;
        }
        .dock_btn:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: scale(1.05);
        }
        .dock_btn:active {
            background: rgba(255, 255, 255, 0.28);
            transform: scale(0.95);
        }
        .dock_btn svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
            margin-bottom: 2px;
        }
        .dock_btn span {
            font-size: 9px;
            font-weight: 600;
            color: #a1a1a6;
        }
        .dock_btn:hover span {
            color: #ffffff;
        }

        /* Responsive adaptations */
        @media (max-width: 480px) {
            #control_dock {
                bottom: 12px;
                padding: 8px 12px;
                gap: 12px;
                border-radius: 16px;
            }
            .dock_btn {
                width: 42px;
                height: 42px;
                border-radius: 10px;
            }
            .dock_btn svg {
                width: 18px;
                height: 18px;
            }
            .dock_btn span {
                font-size: 8px;
            }
            #stats_overlay {
                width: 160px;
                top: 45px;
                right: 8px;
                padding: 8px 10px;
            }
        }
    </style>

    <script type="module" crossorigin="anonymous">
        import RFB from './novnc/core/rfb.js';

        let rfb;
        const statusText = document.getElementById('status_text');
        const statusIndicator = document.getElementById('status_indicator');
        const connectBtn = document.getElementById('connect_btn');
        let userDisconnected = true;

        function updateStatus(text, stateClass) {
            statusText.textContent = text;
            statusIndicator.className = 'vnc_icon ' + stateClass;
            
            if (stateClass === 'status_connected') {
                connectBtn.textContent = 'Disconnect';
                connectBtn.classList.add('connected');
                userDisconnected = false;
            } else if (stateClass === 'status_disconnected') {
                connectBtn.textContent = 'Connect';
                connectBtn.classList.remove('connected');
            } else {
                connectBtn.textContent = 'Connecting...';
                connectBtn.classList.remove('connected');
            }
        }

        function connectedToServer(e) {
            updateStatus('Connected to $DESKTOP', 'status_connected');
        }

        function disconnectedFromServer(e) {
            updateStatus('Disconnected', 'status_disconnected');
            // Auto reconnect only if not manually disconnected by user
            if (!userDisconnected) {
                setTimeout(connect, 3000);
            }
        }

        function credentialsAreRequired(e) {
            const password = prompt("VNC Password Required:");
            rfb.sendCredentials({ password: password });
        }

        function connect() {
            if (rfb && rfb._rfbConnectionState === 'connected') {
                return;
            }
            updateStatus('Connecting...', 'status_connecting');
            userDisconnected = false;
            
            const host = window.location.hostname;
            const port = "$PORT"; 
            const password = new URLSearchParams(window.location.search).get('password') || "";
            const path = "websockify";

            let url = (window.location.protocol === "https:") ? "wss://" : "ws://";
            url += host;
            if (port) {
                url += ":" + port;
            }
            url += "/" + path;

            try {
                if (rfb) {
                    try { rfb.disconnect(); } catch(e) {}
                }
                rfb = new RFB(document.getElementById('screen'), url, { credentials: { password: password } });
                
                rfb.addEventListener("connect", connectedToServer);
                rfb.addEventListener("disconnect", disconnectedFromServer);
                rfb.addEventListener("credentialsrequired", credentialsAreRequired);
                
                rfb.scaleViewport = true;
                rfb.focusOnClick = true;
            } catch (err) {
                updateStatus('Connection Failed', 'status_disconnected');
                if (!userDisconnected) {
                    setTimeout(connect, 3000);
                }
            }
        }

        function disconnect() {
            userDisconnected = true;
            if (rfb) {
                try { rfb.disconnect(); } catch(e) {}
            }
            updateStatus('Disconnected', 'status_disconnected');
        }

        // Connect/Disconnect toggle
        window.toggleConnection = function() {
            if (rfb && rfb._rfbConnectionState === 'connected') {
                disconnect();
            } else {
                connect();
            }
        };

        // Global functions for dock control buttons
        window.sendVncHome = function() {
            if (!rfb || rfb._rfbConnectionState !== 'connected') return;
            rfb._sendMouse(0, 0, 4); // Right click down (Home down)
            setTimeout(() => rfb._sendMouse(0, 0, 0), 100); // Up
        };

        window.sendVncPower = function() {
            if (!rfb || rfb._rfbConnectionState !== 'connected') return;
            rfb._sendMouse(0, 0, 2); // Middle click down (Power down)
            setTimeout(() => rfb._sendMouse(0, 0, 0), 100); // Up
        };

        window.sendVncVolumeUp = function() {
            if (!rfb || rfb._rfbConnectionState !== 'connected') return;
            rfb.sendKey(0x1008ff13, "AudioVolumeUp", true); // Keydown VolUp
            setTimeout(() => rfb.sendKey(0x1008ff13, "AudioVolumeUp", false), 50); // Keyup
        };

        window.sendVncVolumeDown = function() {
            if (!rfb || rfb._rfbConnectionState !== 'connected') return;
            rfb.sendKey(0x1008ff11, "AudioVolumeDown", true); // Keydown VolDown
            setTimeout(() => rfb.sendKey(0x1008ff11, "AudioVolumeDown", false), 50); // Keyup
        };

        // System stats polling loop
        function updateBadgeColor(el, val) {
            el.classList.remove('color_green', 'color_orange', 'color_red');
            if (val > 80) {
                el.classList.add('color_red');
            } else if (val > 55) {
                el.classList.add('color_orange');
            } else {
                el.classList.add('color_green');
            }
        }

        function pollStats() {
            fetch('./stats.js?t=' + Date.now())
                .then(res => {
                    if (!res.ok) throw new Error();
                    return res.json();
                })
                .then(data => {
                    const headerStats = document.getElementById('header_stats');
                    headerStats.style.opacity = '1';

                    // CPU
                    const cpu = Math.round(data.cpu || 0);
                    const cpuBadge = document.getElementById('cpu_badge');
                    cpuBadge.textContent = `CPU: ${cpu}%`;
                    updateBadgeColor(cpuBadge, cpu);

                    // RAM
                    const ramUsed = (data.ram.used / (1024 * 1024 * 1024)).toFixed(1);
                    const ramTotal = (data.ram.total / (1024 * 1024 * 1024)).toFixed(1);
                    const ramPct = Math.round((data.ram.used / data.ram.total) * 100) || 0;
                    const ramBadge = document.getElementById('ram_badge');
                    ramBadge.textContent = `RAM: ${ramUsed}/${ramTotal} GB`;
                    updateBadgeColor(ramBadge, ramPct);

                    // Disk
                    const diskUsed = (data.disk.used / (1024 * 1024 * 1024)).toFixed(1);
                    const diskTotal = (data.disk.total / (1024 * 1024 * 1024)).toFixed(1);
                    const diskPct = Math.round((data.disk.used / data.disk.total) * 100) || 0;
                    const diskBadge = document.getElementById('disk_badge');
                    diskBadge.textContent = `Disk: ${diskUsed}/${diskTotal} GB`;
                    updateBadgeColor(diskBadge, diskPct);
                })
                .catch(() => {
                    document.getElementById('header_stats').style.opacity = '0';
                });
        }

        setInterval(pollStats, 2000);
        pollStats();
    </script>
</head>
<body>
    <div id="status_bar">
        <div class="status_left">
            <div id="status_indicator" class="vnc_icon status_disconnected"></div>
            <span id="status_text">Disconnected</span>
        </div>
        <div id="header_stats" class="header_stats">
            <span class="stat_badge" id="cpu_badge">CPU: --</span>
            <span class="stat_badge" id="ram_badge">RAM: --</span>
            <span class="stat_badge" id="disk_badge">Disk: --</span>
        </div>
        <div class="status_right">
            <button id="connect_btn" class="status_btn" onclick="toggleConnection()">Connect</button>
            <span class="port_text">PORT $PORT</span>
        </div>
    </div>

    <div id="screen">
        <!-- Canvas will be dynamically generated here -->
    </div>

    <!-- IOS Smooth Overlay Dock -->
    <div id="control_dock">
        <!-- HOME Button -->
        <button class="dock_btn" onclick="sendVncHome()" title="Home Button">
            <svg viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" fill="none"/>
                <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
            <span>Home</span>
        </button>

        <!-- POWER Button -->
        <button class="dock_btn" onclick="sendVncPower()" title="Power / Lock">
            <svg viewBox="0 0 24 24">
                <path d="M12 2v10M16.24 7.76a6 6 0 1 1-8.48 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
            </svg>
            <span>Lock</span>
        </button>

        <!-- VOLUME UP Button -->
        <button class="dock_btn" onclick="sendVncVolumeUp()" title="Volume Up">
            <svg viewBox="0 0 24 24">
                <path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
            </svg>
            <span>Vol +</span>
        </button>

        <!-- VOLUME DOWN Button -->
        <button class="dock_btn" onclick="sendVncVolumeDown()" title="Volume Down">
            <svg viewBox="0 0 24 24">
                <path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                <path d="M15 12h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
            </svg>
            <span>Vol -</span>
        </button>
    </div>
</body>
</html>
